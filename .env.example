# Hedera network: testnet (for the demo) or mainnet
HEDERA_NETWORK=testnet

# Your Hedera operator account (from https://portal.hedera.com)
# Account ID looks like: 0.0.xxxxxx
HEDERA_OPERATOR_ID=0.0.xxxxxx

# Operator private key. Works with either DER-encoded (302e...) or hex ED25519/ECDSA keys.
HEDERA_OPERATOR_KEY=

# Optional: reuse an already-created certificate collection instead of creating a new one.
# Leave empty to create a fresh token from the UI.
HEDERA_TOKEN_ID=

# Public base URL used inside NFT metadata (points back to this app's metadata route).
# For local demo, http://localhost:3000 is fine.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Optional: pin certificates to IPFS so images show in wallets and on HashScan.
# Get a free JWT at https://app.pinata.cloud -> API Keys -> New Key.
PINATA_JWT=
PINATA_GATEWAY=https://gateway.pinata.cloud
